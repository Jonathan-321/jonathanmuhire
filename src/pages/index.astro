  <!-- Writing -->
  <section id="writing" class="page-section">
    <div class="writing-list">
      <div class="section-label">Writing</div>
      <h2 class="section-title">Notes and breakdowns.</h2>
      {blog.map((post) => (
        <article class="post-item">
          <time class="post-date">
            {new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
          <h3 class="post-title">
            <Link href={`/blog/${post.id}`} class="project-link">
              {post.data.title}
            </Link>
          </h3>
          {post.data.description && (
            <p class="post-desc">{post.data.description}</p>
          )}
        </article>
      ))}
    </div>
  </section>
  
